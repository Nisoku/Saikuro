# Saikuro development environment
export RUST_BACKTRACE=1
export SAIKURO_LOG=info

# Add local Python venv to PATH if it exists
if [ -d "Build/adapters/python/venv" ]; then
    export PATH="$(pwd)/Build/adapters/python/venv/bin:$PATH"
fi

# Add cargo bin to PATH
export PATH="$HOME/.cargo/bin:$PATH"
